# Backend — Supabase production template
# Fill in DB_PASSWORD and (optionally) REDIS_URL and S3_* for production.

# Direct Postgres host (works with SQLAlchemy + asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:${DB_PASSWORD}@db.znwvrcgrzcxahchjsmyg.supabase.co:5432/postgres
DATABASE_URL_SYNC=postgresql://postgres:${DB_PASSWORD}@db.znwvrcgrzcxahchjsmyg.supabase.co:5432/postgres

# If you prefer Supavisor pooler, replace with your pooler URI from Supabase dashboard.
# DATABASE_URL=postgresql+asyncpg://postgres.znwvrcgrzcxahchjsmyg:${DB_PASSWORD}@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# DATABASE_URL_SYNC=postgresql://postgres.znwvrcgrzcxahchjsmyg:${DB_PASSWORD}@aws-0-us-east-1.pooler.supabase.com:6543/postgres

REDIS_URL=redis://localhost:6379/0
SECRET_KEY=replace-with-strong-64-char-secret
CORS_ORIGINS=https://your-frontend-domain.com
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Object storage (S3/MinIO compatible)
S3_BUCKET=productideas-exports
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Google APIs
# pytrends + autocomplete do not require an API key by default.
GOOGLE_TRENDS_API_KEY=
